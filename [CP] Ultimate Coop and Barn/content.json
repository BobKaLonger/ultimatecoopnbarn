{
	"Format": "2.9.0",
	"ConfigSchema": {
        "Barn Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your barn.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Coop Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your coop.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Ultimate Building Upgrade": {
            "AllowValues": "Auto, Giga, Mega",
            "Description": "Choose which buildings to upgrade, for SVE or Vanilla please select AUTO!",
            "Default": "Auto",
            "Section": "Upgrade Path"
        }
    },
	
	"Changes": [
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Clean_UltimateBarn",
			"FromFile": "assets/clean_UltimateBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Clean_UltimateCoop",
			"FromFile": "assets/clean_UltimateCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Cozy_UltimateBarn",
			"FromFile": "assets/cozy_UltimateBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Cozy_UltimateCoop",
			"FromFile": "assets/cozy_UltimateCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Clean_SuperDenseBarn",
			"FromFile": "assets/clean_SuperDenseBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Clean_SuperDenseCoop",
			"FromFile": "assets/clean_SuperDenseCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Cozy_SuperDenseBarn",
			"FromFile": "assets/cozy_SuperDenseBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_Cozy_SuperDenseCoop",
			"FromFile": "assets/cozy_SuperDenseCoop.tmx"
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_UltimateBarn": "Building/-10 0/Roof/-10 5/Trim/-5 0"
			}
		},
		{
			"Action": "EditData",
			"Target": "Data/PaintData",
			"Entries": {
				"{{ModId}}_UltimateCoop": "Building/-12 0/Roof/-10 5/Trim/-10 5"
		    }
	    },
	    {
            "Action": "EditData",
            "Target": "Data/PaintData",
            "Entries": {
	            "{{ModId}}_SuperDenseBarn": "Building/-15 0/Roof/-10 5/Trim/-10 5"
            }
        },
        {
            "Action": "EditData",
            "Target": "Data/PaintData",
            "Entries": {
	            "{{ModId}}_SuperDenseCoop": "Building/-25 0/Roof/-15 5/Trim/-25 0"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeSVE.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "SVE",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeGiga.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "Giga",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeBoth.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "Both",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeMega.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "Mega",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeGiant.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "Giant",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        },
        {
            "Action": "Include",
            "FromFile": "data/upgradeVanilla.json",
            "When":
            {
                "bobkalonger.UltCB_code/UltimateMode": "Vanilla",
        		"HasMod": "bobkalonger.UltCB_code"
            }
        }
    ]
}
