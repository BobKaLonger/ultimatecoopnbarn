{
	"Format": "2.9.0",
	"ConfigSchema": {
        "Barn Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your barn.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Coop Floor": {
            "AllowValues": "Clean, Cozy",
            "Description": "Choose the interior for your coop.",
            "Default": "Clean",
            "Section": "Indoor Appearance"
        },
        "Ultimate Building Upgrade": {
            "AllowValues": "Auto, Giga, Mega",
            "Description": "Choose which buildings to upgrade, for SVE or Vanilla please select AUTO!",
            "Default": "Auto",
            "Section": "Upgrade Path"
        }
    },
    "DynamicTokens": [
        {
            "Name": "modVPP",
            "Value": "VPP",
            "When": {
                "HasMod": "KediDili.VanillaPlusProfessions",
                "KediDili.VanillaPlusProfessions/EnableOvercrowdingEdits": "true",
                "Query: KediDili.VanillaPlusProfessions_PlayerHasTalent Any Overcrowding": "true"
            }
        },
        {
            "Name": "modVPP",
            "Value": "Base"
        }
    ],
	"Changes": [
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CleanBase_UltimateBarn",
			"FromFile": "assets/clean_UltimateBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CleanBase_UltimateCoop",
			"FromFile": "assets/clean_UltimateCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CozyBase_UltimateBarn",
			"FromFile": "assets/cozy_UltimateBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CozyBase_UltimateCoop",
			"FromFile": "assets/cozy_UltimateCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CleanBase_SuperDenseBarn",
			"FromFile": "assets/clean_SuperDenseBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CleanBase_SuperDenseCoop",
			"FromFile": "assets/clean_SuperDenseCoop.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CozyBase_SuperDenseBarn",
			"FromFile": "assets/cozy_SuperDenseBarn.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CozyBase_SuperDenseCoop",
			"FromFile": "assets/cozy_SuperDenseCoop.tmx"
		},
        {
			"Action": "Load",
			"Target": "Maps/ultimate_CleanVPP_UltimateBarn",
			"FromFile": "assets/clean_UltimateBarnVPP.tmx"
		},
		{
			"Action": "Load",
			"Target": "Maps/ultimate_CleanVPP_UltimateCoop",
			"FromFile": "assets/clean_UltimateCoopVPP.tmx"
